# Copy this file to .env and fill in your values.
# Get Firebase values from: https://console.firebase.google.com
# → Your project → Project settings → Your apps → Web app config

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google Sign-In Web Client ID
# Get from: Google Cloud Console → APIs & Services → Credentials
# → OAuth 2.0 Client IDs → Web client (auto created by Google Service)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com

# Google Maps API Key (for reverse geocoding)
# Get from: Google Cloud Console → APIs & Services → Credentials → Create API key
# Enable: Geocoding API
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
